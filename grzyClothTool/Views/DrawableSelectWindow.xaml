<Window x:Class="grzyClothTool.Views.DrawableSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:grzyClothTool.Controls"
        xmlns:local="clr-namespace:grzyClothTool.Views"
        mc:Ignorable="d"
        Title="Select your drawable properties"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush50}"
        WindowStartupLocation="CenterOwner"
        Height="560"
        Width="680">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>
        <Grid.Resources>
            <Style x:Key="DrawableSelectRowBorder" TargetType="Border">
                <Setter Property="Margin" Value="4,2"/>
                <Setter Property="Padding" Value="8"/>
                <Setter Property="Background" Value="{DynamicResource Brush50}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush200}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding HasAssignedType}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource Brush175}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource Brush600}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource Brush200}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource Brush400}"/>
                    </DataTrigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource Brush500}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>
        <StackPanel Grid.Row="0" Margin="15">
            <TextBlock Text="{Binding HeaderText}" FontSize="16" Foreground="{DynamicResource Brush950}" FontWeight="Medium"/>
            <TextBlock Text="Click rows to check them. Applied files are hidden unless Show typed is enabled."
                       FontSize="12"
                       Foreground="{DynamicResource Brush500}"
                       FontWeight="Light"
                       Margin="0,0,0,14"
                       TextWrapping="Wrap"/>

            <Border BorderBrush="{DynamicResource Brush200}"
                    BorderThickness="1"
                    Background="{DynamicResource Brush100}"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="8,6">
                        <TextBlock Text="{Binding SelectionSummary}"
                                   Foreground="{DynamicResource Brush600}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <CheckBox Content="Show typed"
                                      IsChecked="{Binding ShowTypedItems, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      Margin="4,0,10,0"
                                      Foreground="{DynamicResource Brush700}"/>
                            <Button Content="Select All"
                                    Width="80"
                                    Height="26"
                                    Margin="4,0,0,0"
                                    Click="SelectAll_Click"/>
                            <Button Content="Select None"
                                    Width="86"
                                    Height="26"
                                    Margin="4,0,0,0"
                                    Click="SelectNone_Click"/>
                        </StackPanel>
                    </DockPanel>
                    <ScrollViewer Grid.Row="1"
                                  MaxHeight="275"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding VisibleDrawableItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DrawableSelectRowBorder}"
                                            MouseLeftButtonUp="DrawableItem_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      IsHitTestVisible="False"
                                                      Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding FileName}"
                                                           Foreground="{DynamicResource Brush950}"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding FilePath}"
                                                           Foreground="{DynamicResource Brush500}"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AssignedText}"
                                                       Foreground="{DynamicResource Brush600}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Margin="12,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasAssignedType}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource Brush900}"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="155"/>
                </Grid.ColumnDefinitions>
                <c:ModernLabelComboBox
                    Grid.Column="0"
                    x:Name="assetType"
                    Label="Asset type"
                    ItemsSource="{Binding AssetTypes}"
                    SelectedItem="{Binding SelectedAssetType}"
                    Margin="0,0,0,5"
                    IsUpdated="AssetType_IsUpdated"
                />
                <c:ModernLabelComboBox
                    Grid.Column="2"
                    x:Name="drawableType"
                    Label="Drawable type"
                    IsEnabled="{Binding IsAssetTypeSelected}"
                    ItemsSource="{Binding DrawableTypes}"
                    SelectedItem="{Binding SelectedDrawableType}"
                    Margin="0,0,0,5"
                />
                <c:CustomButton
                    Grid.Column="4"
                    x:Name="apply"
                    Label="Apply to checked"
                    CornerRadius="5"
                    Height="40"
                    VerticalAlignment="Top"
                    Margin="0,5,0,5"
                    IsEnabled="{Binding IsApplyEnabled}"
                    MyBtnClickEvent="ApplySelected_MyBtnClickEvent"/>
            </Grid>
        </StackPanel>
        <Grid Grid.Row="1" Margin="5">
            <c:CustomButton 
                HorizontalAlignment="Left"
                x:Name="cancel"
                CornerRadius="5"
                Width="150"
                Label="Cancel"
                MyBtnClickEvent="Cancel_MyBtnClickEvent"
             />
            <c:CustomButton 
                HorizontalAlignment="Right"
                x:Name="select"
                CornerRadius="5"
                Width="150"
                Label="Continue"
                IsEnabled="{Binding IsSubmitEnabled}"
                MyBtnClickEvent="Select_MyBtnClickEvent"
             />
        </Grid>
    </Grid>
</Window>
